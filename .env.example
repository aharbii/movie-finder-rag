# =============================================================================
# rag_ingestion — environment template
# Copy to .env and fill in values before running.
# After a successful run, share QDRANT_ENDPOINT, QDRANT_API_KEY,
# QDRANT_COLLECTION, and EMBEDDING_MODEL with the chain team.
# Never commit .env to version control.
# =============================================================================

# --- Vector store (Qdrant Cloud) --------------------------------------------
QDRANT_ENDPOINT=https://your-cluster.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=movies

# --- Embeddings --------------------------------------------------------------
OPENAI_API_KEY=sk-
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# --- Kaggle dataset download -------------------------------------------------
# Generate at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Optional: ChromaDB (local fallback) ------------------------------------
# Set VECTOR_STORE=chromadb in environment to use ChromaDB instead of Qdrant
VECTOR_STORE=qdrant
